/*【问题描述】
n皇后问题研究的是如何将n个皇后放置在n×n的棋盘上，并且使皇后彼此之间不能相互攻击。给定一个整数n，返回n皇后不同的解决方案的数量。要求设计如下函数：
class Solution{
public:
 int totalNQueens(int n)
 {  … }
};
【输入形式】
    输入一个整数n。
【输出形式】
       输出n皇后问题的解决方案的数量。
【样例输入】
6
【样例输出】
     4
【样例说明】
      6皇后问题有4个不同的求解方案。测试数据存放在in.txt文件中。 
【评分标准】
      共10个测试用例，每通过一个测试得10分。*/
#include <iostream>
#include <fstream>
#include <vector>
using namespace std;

class Solution 
{
public:
    int totalNQueens(int n)
    {
        int res = 0;
        // 标记列、主对角线、副对角线是否被占用
        vector<bool> col(n, false);
        vector<bool> diag1(2 * n, false);
        vector<bool> diag2(2 * n, false);

        // 回溯搜索
        backtrack(0, n, col, diag1, diag2, res);
        return res;
    }

private:
    // 回溯函数：row = 当前处理到第几行
    void backtrack(int row, int n, vector<bool>& col,
        vector<bool>& d1, vector<bool>& d2, int& res) 
    {
        if (row == n) 
        { // 找到一种解法
            res++;
            return;
        }
        for (int i = 0; i < n; i++) 
        { // 遍历当前行的每一列
            // 检查当前位置是否可以放皇后
            if (!col[i] && !d1[row + i] && !d2[row - i + n]) 
            {
                // 放置皇后
                col[i] = true;
                d1[row + i] = true;
                d2[row - i + n] = true;

                // 递归下一行
                backtrack(row + 1, n, col, d1, d2, res);

                // 回溯，撤销选择
                col[i] = false;
                d1[row + i] = false;
                d2[row - i + n] = false;
            }
        }
    }
};

// 主函数：读取文件、调用函数、输出结果
int main() 
{
    int n;
    ifstream fin("in.txt");
    fin >> n;

    Solution sol;
    cout << sol.totalNQueens(n) << endl;

    return 0;
}




